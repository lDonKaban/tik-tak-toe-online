{
  "name": "tik-tak-toe-online",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm build:css && concurrently \"tailwindcss -i src/tailwind-input.css -o src/app/globals.css --watch\" \"next dev\"",
    "build": "pnpm build:css && next build",
    "build:css": "tailwindcss -i src/tailwind-input.css -o src/app/globals.css",
    "build:css:watch": "tailwindcss -i src/tailwind-input.css -o src/app/globals.css --watch",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "db:migrate:dev": "prisma migrate dev",
    "db:reset": "prisma migrate reset && prisma db seed"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cuid": "^3.0.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
